APP_NAME=aiPal
APP_ENV=production
APP_KEY=                          # Run: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://yourdomain.com

# Caddy uses these for HTTPS certificate
APP_DOMAIN=yourdomain.com
ACME_EMAIL=you@example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ─── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=aipal
DB_USERNAME=aipal
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Cache / Queue / Session ─────────────────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_PORT=6379

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AI Providers ─────────────────────────────────────────────────────────────
AI_DEFAULT_PROVIDER=anthropic

ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

XAI_API_KEY=
XAI_DEFAULT_MODEL=grok-2-latest

GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

ELEVENLABS_API_KEY=

# ─── Voice ────────────────────────────────────────────────────────────────────
STT_PROVIDER=openai
TTS_PROVIDER=openai
OPENAI_TTS_VOICE=alloy

# ─── Messaging ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=          # Run: openssl rand -hex 16

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=            # Any random string
WHATSAPP_APP_SECRET=

# ─── Integrations ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="https://yourdomain.com/google/callback"

# ─── Horizon ──────────────────────────────────────────────────────────────────
HORIZON_DOMAIN=
HORIZON_PATH=horizon

# ─── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
