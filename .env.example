APP_NAME=aiPal
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
# Use 'postgres' when running via Docker Compose, '127.0.0.1' for local dev
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=aipal
DB_USERNAME=aipal
DB_PASSWORD=secret

# ─── Cache / Queue / Session ─────────────────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

REDIS_CLIENT=phpredis
# Use 'redis' when running via Docker Compose, '127.0.0.1' for local dev
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Default provider for chat (anthropic | openai | deepseek | xai | gemini | ollama)
AI_DEFAULT_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# xAI (Grok)
XAI_API_KEY=
XAI_DEFAULT_MODEL=grok-2-latest

# Gemini
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# Ollama (local models — used for offline/Raspberry Pi setups)
OLLAMA_HOST=http://ollama:11434
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=

# ─── Agent Model Overrides ────────────────────────────────────────────────────
# Override provider/model for each background agent independently.
# Leave blank to use AI_DEFAULT_PROVIDER and its default model.
# Providers: anthropic | openai | deepseek | xai | gemini | ollama
MEMORY_EXTRACTOR_PROVIDER=
MEMORY_EXTRACTOR_MODEL=

DAILY_BRIEFING_PROVIDER=
DAILY_BRIEFING_MODEL=

REMINDER_PARSER_PROVIDER=
REMINDER_PARSER_MODEL=

# ─── Embeddings ───────────────────────────────────────────────────────────────
# Provider for embeddings (memories, documents, notes search).
# If changed, dimensions may need to match your model and a DB migration is required.
# Providers: openai | ollama | gemini
AI_DEFAULT_EMBEDDINGS_PROVIDER=openai
AI_EMBEDDING_MODEL=
AI_EMBEDDING_DIMENSIONS=1536

# ─── Voice ────────────────────────────────────────────────────────────────────
# STT provider for voice transcription (openai | gemini)
AI_DEFAULT_STT_PROVIDER=openai
AI_STT_MODEL=

# TTS provider for voice output (openai | elevenlabs)
AI_DEFAULT_AUDIO_PROVIDER=openai
AI_TTS_MODEL=
OPENAI_TTS_VOICE=alloy

# ─── Messaging ────────────────────────────────────────────────────────────────
# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# WhatsApp (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ─── Integrations ─────────────────────────────────────────────────────────────
# Google (Calendar + Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# GitLab
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=

# Jira
JIRA_HOST=
JIRA_EMAIL=
JIRA_TOKEN=

# ─── Horizon ──────────────────────────────────────────────────────────────────
HORIZON_DOMAIN=
HORIZON_PATH=horizon

# ─── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ─── PWA / Web Push ───────────────────────────────────────────────────────────
# Generate with: php artisan pwa:vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
